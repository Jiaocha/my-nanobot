{
  "providers": {
    "openrouter": {
      "apiKey": "sk-or-v1-YOUR_API_KEY"
    }
  },
  "agents": {
    "defaults": {
      "model": "anthropic/claude-opus-4-5",
      "vision_model": "openai/gpt-4o",
      "provider": "openrouter"
    }
  },
  "tools": {
    "mcp_servers": {
      "sqlite": {
        "command": "uvx",
        "args": [
          "mcp-server-sqlite",
          "--db-path",
          "~/.nanobot/workspace.db"
        ]
      },
      "postgres": {
        "command": "uvx",
        "args": [
          "mcp-server-postgres",
          "postgresql://user:pass@localhost:5432/mydb"
        ]
      },
      "kubernetes": {
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-kubernetes"
        ]
      }
    }
  }
}
